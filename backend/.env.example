# Multi-Agent RFP System Environment Configuration

# Application Settings
APP_NAME="Multi-Agent RFP System"
VERSION="1.0.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security Settings
SECRET_KEY=your-secret-key-change-in-production-please-use-a-strong-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
DATABASE_URL=postgresql+asyncpg://rfp_user:rfp_password@localhost:5432/rfp_system
DATABASE_ECHO=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Message Queue Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Agent Configuration
RFP_MONITORING_INTERVAL=300
MAX_CONCURRENT_RFPS=10
AGENT_TIMEOUT=300

# External API Configuration
COMMODITY_API_KEY=your-commodity-api-key-here
COMMODITY_API_URL=https://api.commodities-api.com/v1

# ML/NLP Configuration
SPACY_MODEL=en_core_web_sm
TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2
ML_MODEL_CACHE_DIR=./models

# Web Scraping Configuration
SCRAPING_USER_AGENT=RFP-Agent/1.0
SCRAPING_DELAY=1.0
MAX_SCRAPING_WORKERS=5

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Storage Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=*